-- FUNCIONES RPC NUEVAS
-- ══════════════════════════════════════════════════════════════════

-- Trunca hwid_temp_bans (usado por /api/hwid_bans/clear sin hwid)
CREATE OR REPLACE FUNCTION truncate_hwid_bans()
RETURNS VOID LANGUAGE plpgsql AS $$
BEGIN
    TRUNCATE TABLE hwid_temp_bans;
END;
$$;

-- Trunca hwid_fail_log (usado junto con truncate_hwid_bans)
CREATE OR REPLACE FUNCTION truncate_hwid_fail_log()
RETURNS VOID LANGUAGE plpgsql AS $$
BEGIN
    TRUNCATE TABLE hwid_fail_log;
END;
$$;

-- Limpia entradas antiguas de rate_limit_log (ventana = 60 s por defecto)
-- Llama a esta función desde un cron job cada minuto para mantener
-- la tabla pequeña y las consultas rápidas.
CREATE OR REPLACE FUNCTION purge_old_rate_limit_log(window_secs DOUBLE PRECISION DEFAULT 60)
RETURNS INT LANGUAGE plpgsql AS $$
DECLARE
    deleted INT;
BEGIN
    DELETE FROM rate_limit_log
    WHERE ts < (EXTRACT(EPOCH FROM NOW()) - window_secs);
    GET DIAGNOSTICS deleted = ROW_COUNT;
    RETURN deleted;
END;
$$;

-- Limpia entradas antiguas de hwid_fail_log (ventana = 600 s por defecto)
CREATE OR REPLACE FUNCTION purge_old_hwid_fail_log(window_secs DOUBLE PRECISION DEFAULT 600)
RETURNS INT LANGUAGE plpgsql AS $$
DECLARE
    deleted INT;
BEGIN
    DELETE FROM hwid_fail_log
    WHERE ts < (EXTRACT(EPOCH FROM NOW()) - window_secs);
    GET DIAGNOSTICS deleted = ROW_COUNT;
    RETURN deleted;
END;
$$;


