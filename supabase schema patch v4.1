-- ── HWID FAIL LOG ────────────────────────────────────────────────
-- Reemplaza el dict _hwid_fail_log en memoria.
-- Registra cada intento fallido por HWID con su timestamp.
-- El servidor cuenta los fallos dentro de la ventana de tiempo
-- para decidir si aplica un ban temporal.

CREATE TABLE IF NOT EXISTS hwid_fail_log (
    id      BIGSERIAL        PRIMARY KEY,
    hwid    TEXT             NOT NULL,
    ts      DOUBLE PRECISION NOT NULL    -- unix timestamp
);

CREATE INDEX IF NOT EXISTS idx_hwid_fail_log_hwid ON hwid_fail_log(hwid);
CREATE INDEX IF NOT EXISTS idx_hwid_fail_log_ts   ON hwid_fail_log(ts);

ALTER TABLE hwid_fail_log ENABLE ROW LEVEL SECURITY;
-- Sin políticas = solo service_role puede acceder.


-- ── RATE LIMIT LOG ───────────────────────────────────────────────
-- Reemplaza el dict _rate_limit en memoria.
-- Registra cada petición por IP con su timestamp.
-- El servidor cuenta las peticiones en la ventana de 60 s.

CREATE TABLE IF NOT EXISTS rate_limit_log (
    id      BIGSERIAL        PRIMARY KEY,
    ip      TEXT             NOT NULL,
    ts      DOUBLE PRECISION NOT NULL    -- unix timestamp
);

CREATE INDEX IF NOT EXISTS idx_rate_limit_log_ip ON rate_limit_log(ip);
CREATE INDEX IF NOT EXISTS idx_rate_limit_log_ts ON rate_limit_log(ts);

ALTER TABLE rate_limit_log ENABLE ROW LEVEL SECURITY;
-- Sin políticas = solo service_role puede acceder.


